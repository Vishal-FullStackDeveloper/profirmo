PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
JWT_SECRET=replace_with_secure_secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_DAYS=30

# MySQL database connection
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=demo_project_db
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_DIALECT=mysql
DB_SSL=false

# Phase-6: jobs / email / notifications
APP_URL=http://localhost:3000
EMAIL_FROM=Profirmo <no-reply@profirmo.com>
# Email delivery mode: dev | smtp
EMAIL_TRANSPORT=dev
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_SECURE=false
JOB_POLL_MS=4000
EMAIL_VERIFICATION_EXPIRY_HOURS=48

# Razorpay — server-side keys for Standard Checkout + signature verification.
# Get test keys from https://dashboard.razorpay.com/app/keys
# RAZORPAY_KEY_ID must also be exposed to the frontend as
# NEXT_PUBLIC_RAZORPAY_KEY_ID in frontend/.env.local — the SECRET must
# NEVER reach the browser.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay webhook secret (set in Razorpay dashboard → Webhooks). Used to
# verify the payload signature on POST /api/payments/webhook.
RAZORPAY_WEBHOOK_SECRET=
# Platform fee in basis points (1000 = 10%). Applied to each consultation
# payment; the rest goes to the professional's escrow balance.
PLATFORM_FEE_BPS=1000
